{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TMVideo",
  "version": "0.2.3",
  "identifier": "com.tmvideo.desktop",
  "build": {
    "devUrl": null,
    "frontendDist": "../ui",
    "beforeDevCommand": "npm run build:css",
    "beforeBuildCommand": "npm run build:css"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TMVideo - v0.2.3",
        "width": 1028,
        "height": 786,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "fileAssociations": [
      {
        "name": "TMVideo Project",
        "ext": ["tmv", "tmvz"],
        "description": "TMVideo Project File",
        "role": "Editor"
      },
      {
        "name": "Media File",
        "ext": ["mp4", "mkv", "avi", "mov", "mpg", "mpeg"],
        "description": "Media File",
        "role": "Viewer"
      }
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
